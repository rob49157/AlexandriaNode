datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Replaces MongoDB Upload Schema
model Upload {
  arweaveHash       String   @id // Primary Key (mapped to original identifier)
  title             String
  author            String
  category          String
  description       String
  uploader          String // Wallet address
  uploadTimestamp   DateTime @default(now())
  status            String // "pending" | "challenged" | "approved" | "rejected"
  fileSize          Int // Bytes
  sha256Hash        String   @unique // Unique index for exact duplicate detection
  simHash           String // For near-duplicate detection reference
  litEncryptedKeyId String // Reference to Lit Protocol encrypted key
  onChainTxHash     String? // Transaction hash of on-chain registration (optional initially)

  @@index([title, author]) // Index for search queries
}

// Replaces MongoDB Synced Event Schema
model Event {
  id              Int      @id @default(autoincrement())
  eventName       String // e.g., "BookRented", "StakeDeposited"
  arweaveHash     String
  args            Json // Event arguments stored as JSON object
  blockNumber     Int
  transactionHash String
  timestamp       DateTime
}
